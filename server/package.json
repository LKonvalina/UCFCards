{
  "name": "server",
  "version": "1.0.0",
  "description": "Blackjack learning game backend",
  "main": "src/index.js",
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_ENV=dev nodemon -r dotenv/config src/index.js",
    "start": "cross-env NODE_ENV=prod node src/index.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles",
    "playtest": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js bots.playtest --runInBand",
    "test:ci": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles --ci --coverage"
  },
  "dependencies": {
    "@clerk/backend": "^3.11.2",
    "@clerk/express": "^2.1.38",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "mongoose": "^9.7.4",
    "socket.io": "^4.8.3"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "mongodb-memory-server": "^11.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^7.2.2"
  }
}
